:root {
  --bg: #f5f7f3;
  --bg-light: #fbfcf8;
  --surface: #ffffff;
  --text: #19231d;
  --muted: #5d675f;
  --line: #dfe6dc;
  --primary: #163d2d;
  --primary-light: #24583f;
  --accent: #b7854c;
  --accent-soft: #f0dfca;
  --dark: #101915;
  --white: #ffffff;
  --shadow: 0 24px 60px rgba(19, 41, 31, 0.12);
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Pretendard", "Noto Sans KR", "Segoe UI", sans-serif;
  word-break: keep-all;
}

a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }

.container { width: min(1120px, calc(100% - 40px)); margin: 0 auto; }

.site-header {
  position: sticky;
  top: 0;
  z-index: 30;
  background: rgba(245, 247, 243, 0.86);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--line);
}

.header-inner { height: 74px; display: flex; align-items: center; justify-content: space-between; }
.brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 900; letter-spacing: -0.02em; }
.brand-mark { width: 40px; height: 40px; border-radius: 50%; background: var(--primary); color: var(--white); display: inline-flex; align-items: center; justify-content: center; font-size: 16px; }
.brand-text { font-size: 18px; }
.nav { display: flex; gap: 24px; color: var(--muted); font-size: 15px; font-weight: 700; }
.nav a:hover { color: var(--primary); }

.hero { padding: 92px 0 86px; }
.hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 58px; align-items: center; }
.eyebrow { margin: 0 0 14px; color: var(--accent); font-size: 13px; font-weight: 900; letter-spacing: 0.12em; }
h1, h2, h3, p { margin-top: 0; }
h1 { margin-bottom: 24px; font-size: clamp(42px, 6vw, 72px); line-height: 1.06; letter-spacing: -0.07em; }
.hero-description { max-width: 640px; color: #4d5850; font-size: 20px; line-height: 1.78; }
.hero-actions { display: flex; gap: 12px; margin-top: 34px; }
.button { min-height: 52px; padding: 0 23px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; font-weight: 900; transition: 0.2s ease; border: 1px solid transparent; }
.button.primary { background: var(--primary); color: var(--white); }
.button.primary:hover { background: var(--primary-light); transform: translateY(-2px); }
.button.secondary { background: var(--surface); border-color: var(--line); }
.button.secondary:hover { border-color: var(--primary); transform: translateY(-2px); }
.button.ghost { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); color: var(--white); }
.button.full { width: 100%; }
.hero-info { margin-top: 28px; display: flex; flex-wrap: wrap; gap: 10px; }
.hero-info span { padding: 9px 13px; border-radius: 999px; background: var(--surface); border: 1px solid var(--line); color: var(--muted); font-size: 14px; font-weight: 700; }
.hero-visual { position: relative; }
.hero-visual img { width: 100%; aspect-ratio: 4/5; object-fit: cover; object-position: center top; border-radius: 36px; box-shadow: var(--shadow); border: 1px solid var(--line); }
.floating-card { position: absolute; left: -26px; bottom: 28px; width: min(340px, 86%); padding: 22px; background: rgba(255, 255, 255, 0.92); backdrop-filter: blur(12px); border: 1px solid var(--line); border-radius: 24px; box-shadow: 0 18px 40px rgba(19, 41, 31, 0.14); }
.floating-card p { margin: 0 0 8px; color: var(--accent); font-size: 12px; font-weight: 900; letter-spacing: 0.12em; }
.floating-card strong { display: block; margin-bottom: 6px; color: var(--primary); font-size: 20px; }
.floating-card span { color: var(--muted); line-height: 1.6; }

.section { padding: 88px 0; }
.section.light { background: var(--bg-light); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
.section.dark { background: var(--dark); color: var(--white); }
.section-heading { max-width: 760px; margin-bottom: 38px; }
.section-heading.center { margin-left: auto; margin-right: auto; text-align: center; }
.section-heading h2, .system-grid h2, .coach-copy h2, .case-box h2, .location-grid h2, .contact-grid h2 { margin-bottom: 18px; font-size: clamp(30px, 4vw, 48px); line-height: 1.18; letter-spacing: -0.05em; }
.section-heading p, .system-grid p, .coach-copy p, .case-box p, .location-grid p, .contact-grid p { color: var(--muted); font-size: 18px; line-height: 1.8; }
.dark .system-grid p { color: rgba(255,255,255,0.72); }

.split-section { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 56px; align-items: start; }
.sticky-heading { position: sticky; top: 104px; }
.check-list { display: grid; gap: 14px; }
.check-item { display: flex; gap: 14px; align-items: flex-start; padding: 22px; background: var(--surface); border: 1px solid var(--line); border-radius: 22px; }
.check-item span { width: 28px; height: 28px; flex: 0 0 28px; border-radius: 50%; background: var(--primary); color: var(--white); display: inline-flex; align-items: center; justify-content: center; font-weight: 900; }
.check-item p { margin: 0; color: #334039; line-height: 1.65; font-weight: 700; }

.service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
.service-card { min-height: 360px; padding: 30px; background: var(--surface); border: 1px solid var(--line); border-radius: 28px; box-shadow: 0 14px 36px rgba(19, 41, 31, 0.06); }
.service-eyebrow { margin-bottom: 18px; color: var(--accent); font-size: 12px; font-weight: 900; letter-spacing: 0.12em; }
.service-card h3 { margin-bottom: 16px; color: var(--primary); font-size: 25px; }
.service-card p { color: var(--muted); line-height: 1.78; }
.service-card ul { margin: 22px 0 0; padding-left: 18px; color: #3c473f; line-height: 1.9; font-weight: 700; }

.system-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 54px; align-items: center; }
.system-card { padding: 34px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.13); border-radius: 28px; }
.system-card h3 { margin-bottom: 18px; font-size: 26px; }
.system-card ul { margin: 0 0 26px; padding-left: 18px; line-height: 2; color: rgba(255,255,255,0.82); }

.process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.process-card { padding: 26px; background: var(--surface); border: 1px solid var(--line); border-radius: 24px; }
.process-card h3 { color: var(--primary); font-size: 21px; }
.process-card p { margin-bottom: 0; color: var(--muted); line-height: 1.75; }

.coach-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 54px; align-items: center; }
.coach-image-card img { width: 100%; border-radius: 30px; border: 1px solid var(--line); box-shadow: var(--shadow); }
.lead { font-size: 21px !important; color: #2e3a32 !important; font-weight: 700; }
.credential-box { margin-top: 28px; padding: 24px; background: var(--surface); border: 1px solid var(--line); border-radius: 22px; }
.credential-box h3 { color: var(--primary); }
.credential-box p { margin-bottom: 0; }

.case-section { background: linear-gradient(180deg, var(--bg), #edf3ec); }
.case-box { padding: 44px; background: var(--surface); border: 1px solid var(--line); border-radius: 32px; box-shadow: var(--shadow); }
.case-box p:last-child { margin-bottom: 0; }

.location-section { background: var(--surface); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
.location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
.location-card { padding: 32px; background: var(--bg-light); border: 1px solid var(--line); border-radius: 26px; }
.location-card h3 { color: var(--primary); font-size: 25px; }
dl { margin: 0; display: grid; gap: 16px; }
dl div { display: grid; grid-template-columns: 110px 1fr; gap: 18px; padding-bottom: 16px; border-bottom: 1px solid var(--line); }
dl div:last-child { border-bottom: 0; padding-bottom: 0; }
dt { color: var(--muted); font-weight: 800; }
dd { margin: 0; font-weight: 900; }

.contact-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 42px; align-items: start; }
.contact-card { padding: 34px; background: var(--surface); border: 1px solid var(--line); border-radius: 28px; box-shadow: 0 14px 36px rgba(19, 41, 31, 0.06); }
.contact-card h3 { margin-bottom: 18px; color: var(--primary); font-size: 25px; }
.contact-card ul { margin: 0 0 26px; padding-left: 22px; color: var(--muted); line-height: 1.95; font-weight: 700; }
.contact-actions { display: grid; gap: 12px; }
.small-text { margin: 14px 0 0; color: #879087; font-size: 13px !important; line-height: 1.6 !important; }

.footer { padding: 34px 0; background: var(--dark); color: rgba(255,255,255,0.72); }
.footer-inner { display: flex; justify-content: space-between; gap: 28px; }
.footer strong { color: var(--white); font-size: 18px; }
.footer p { margin: 6px 0 0; }

@media (max-width: 920px) {
  .nav { display: none; }
  .hero { padding: 64px 0; }
  .hero-grid,
  .split-section,
  .system-grid,
  .coach-grid,
  .location-grid,
  .contact-grid { grid-template-columns: 1fr; }
  .sticky-heading { position: static; }
  .service-grid,
  .process-grid { grid-template-columns: 1fr; }
  .hero-actions { flex-direction: column; }
  .button { width: 100%; }
  .floating-card { position: static; width: 100%; margin-top: 16px; }
  .coach-image-card { order: 2; }
  .footer-inner { flex-direction: column; }
  h1 { font-size: clamp(40px, 12vw, 58px); }
}
