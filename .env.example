# RePERFORMANCE data store
# PostgreSQL is the primary store when any of these URLs is set.
DATABASE_URL=
POSTGRES_URL=
RP_DATABASE_URL=
RP_DATA_SOURCE=
RP_DATABASE_POOL_MAX=
RP_DATABASE_SSL=
# Set true only after all checked-in migrations pass against the target database.
RP_DISABLE_RUNTIME_SCHEMA_SYNC=false
RP_RUNTIME_SCHEMA_SYNC=

# Canonical origins and trusted alternate origins
NEXT_PUBLIC_SITE_URL=
RP_SITE_URL=
RP_ALLOWED_ORIGINS=

# Google Drive / Sheets backup store
# Used as a backup path for customer data and as a fallback during migration.
RP_SHEETS_WEBAPP_URL=
RP_AUTH_WEBAPP_URL=
RP_SIGNUP_WEBAPP_URL=
RP_API_SECRET=
RP_SHEET_ID=
RP_MEMBERS_GID=
# Disabled unless a web app URL, RP_API_SECRET, and an explicit true flag are all set.
RP_GOOGLE_DRIVE_BACKUP_ENABLED=
RP_SERVICE_APPLICATION_BACKUP_ENABLED=
# Legacy Apps Script compatibility only. Keep false unless the script cannot read headers/body secrets.
RP_BACKUP_SECRET_IN_QUERY=false

# Public consultation booking
# Slots are fixed to weekdays 09:00-22:00 (30 minutes); these values only control lead time and horizon.
RP_CONSULTATION_MIN_LEAD_HOURS=2
RP_CONSULTATION_HORIZON_DAYS=45

# Staff notification after a consultation application is stored successfully
# Free Gmail delivery through the repository Apps Script bridge:
# RP_APPLICATION_NOTIFICATION_PROVIDER=google-apps-script
# RP_APPLICATION_NOTIFICATION_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/.../exec
RP_APPLICATION_NOTIFICATION_PROVIDER=
RP_APPLICATION_NOTIFICATION_GOOGLE_SCRIPT_URL=
RP_APPLICATION_NOTIFICATION_WEBHOOK_URL=
RP_APPLICATION_NOTIFICATION_WEBHOOK_SECRET=
RP_APPLICATION_NOTIFICATION_TIMEOUT_MS=5000

# Login / account security
RP_ADMIN_SESSION_SECRET=
RP_PASSWORD_HASH_SECRET=
RP_IDENTITY_VERIFICATION_SECRET=
RP_ACCOUNT_RECOVERY_SECRET=
RP_SECURITY_EVENT_SECRET=
RP_ALLOW_ENV_AUTH_ACCOUNTS=false

# Database-backed login lockout
RP_AUTH_LOCKOUT_ENABLED=true
RP_AUTH_LOCKOUT_FAILURE_LIMIT=8
RP_AUTH_LOCKOUT_WINDOW_SECONDS=900
RP_AUTH_LOCKOUT_SECONDS=1800

# Login session lifetime
# Defaults to 14 days when unset. The app enforces at least 1 day.
RP_SESSION_TTL_DAYS=14
RP_SESSION_TTL_SECONDS=
RP_ADMIN_SESSION_TTL_DAYS=
RP_ADMIN_SESSION_TTL_SECONDS=

# Seed / emergency accounts
# Prefer PostgreSQL accounts for normal operation.
RP_ADMIN_USERNAME=
RP_ADMIN_PASSWORD=
RP_ADMIN_NAME=
RP_ADMIN_ROLE=admin
RP_AUTH_USERS=
RP_ADMIN_USERS=
RP_TRAINER_USERNAME=
RP_TRAINER_PASSWORD=
RP_TRAINER_NAME=
RP_TRAINER_USERS=

# Identity verification delivery
# Signup and account recovery can send codes by phone, email, or Kakao.
RP_SMS_WEBHOOK_URL=
RP_EMAIL_WEBHOOK_URL=
RP_KAKAO_WEBHOOK_URL=
SMS_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=
KAKAO_WEBHOOK_URL=
RP_IDENTITY_WEBHOOK_SECRET=
RP_SMS_WEBHOOK_SECRET=

# AI features
OPENAI_API_KEY=
OPENAI_MODEL=
RP_AI_DAILY_LIMIT_MAX=100
RP_AI_MEMBER_DAILY_LIMIT=5
RP_AI_STAFF_DAILY_LIMIT=20
RP_AI_DAILY_LIMIT=

# Shared abuse controls and outbound request bounds
RP_RATE_LIMIT_FAIL_CLOSED=false
RP_RATE_LIMIT_FAIL_CLOSED_RETRY_SECONDS=60
RP_OUTBOUND_FETCH_TIMEOUT_MS=10000

# Retention maintenance. Keep apply mode false until backup/restore approval is complete.
CRON_SECRET=
RP_MAINTENANCE_CRON_SECRET=
RP_RETENTION_CRON_APPLY=false
RP_RETENTION_ALLOW_APPLY=false

# Local production verification only. Never commit actual tokens or session cookies.
RP_VERCEL_TEAM_ID=
RP_VERCEL_PROJECT_ID=
# Optional comma-separated override for exceptional multi-project audits.
RP_VERCEL_PROJECT_IDS=
RP_VERCEL_TOKEN=
RP_VERCEL_FIREWALL_ALLOW_APPLY=false
RP_SYSTEM_STATUS_COOKIE=
