# RePERFORMANCE data store
# PostgreSQL is the primary store when any of these URLs is set.
DATABASE_URL=
POSTGRES_URL=
RP_DATABASE_URL=
RP_DATA_SOURCE=
RP_DATABASE_POOL_MAX=
RP_DATABASE_SSL=

# Google Drive / Sheets backup store
# Used as a backup path for customer data and as a fallback during migration.
RP_SHEETS_WEBAPP_URL=
RP_AUTH_WEBAPP_URL=
RP_SIGNUP_WEBAPP_URL=
RP_API_SECRET=
RP_SHEET_ID=
RP_MEMBERS_GID=

# Login / account security
RP_ADMIN_SESSION_SECRET=
RP_PASSWORD_HASH_SECRET=
RP_IDENTITY_VERIFICATION_SECRET=
RP_ACCOUNT_RECOVERY_SECRET=

# Login session lifetime
# Defaults to 90 days when unset. The app enforces at least 1 day.
RP_SESSION_TTL_DAYS=90
RP_SESSION_TTL_SECONDS=
RP_ADMIN_SESSION_TTL_DAYS=
RP_ADMIN_SESSION_TTL_SECONDS=

# Seed / emergency accounts
# Prefer PostgreSQL accounts for normal operation.
RP_ADMIN_USERNAME=
RP_ADMIN_PASSWORD=
RP_ADMIN_NAME=
RP_ADMIN_ROLE=admin
RP_AUTH_USERS=
RP_ADMIN_USERS=
RP_TRAINER_USERNAME=
RP_TRAINER_PASSWORD=
RP_TRAINER_NAME=
RP_TRAINER_USERS=

# Identity verification delivery
# Signup and account recovery can send codes by phone, email, or Kakao.
RP_SMS_WEBHOOK_URL=
RP_EMAIL_WEBHOOK_URL=
RP_KAKAO_WEBHOOK_URL=
SMS_WEBHOOK_URL=
EMAIL_WEBHOOK_URL=
KAKAO_WEBHOOK_URL=
RP_IDENTITY_WEBHOOK_SECRET=
RP_SMS_WEBHOOK_SECRET=

# AI features
OPENAI_API_KEY=
OPENAI_MODEL=

# NORE API bridge
NORE_API_BASE_URL=
NORE_API_KEY=
NORE_API_KEY_HEADER=Authorization
NORE_API_KEY_PREFIX=Bearer
NORE_ORG_ID=
NORE_TIMEOUT_MS=12000

# NORE member card sync
NORE_MEMBER_CARD_ENDPOINT=/members

# NORE AI chat links
NORE_CHAT_URL=
NORE_MEMBER_CHAT_URL=
NORE_PE_EXAM_CHAT_URL=
NORE_CHAT_TOKEN=
NORE_MEMBER_CHAT_TOKEN=
NORE_PE_EXAM_CHAT_TOKEN=
NORE_CHAT_TOKEN_PARAM=token

# NORE nutrition analysis
NORE_NUTRITION_ANALYSIS_ENDPOINT=/nutrition/analyze
NORE_NUTRITION_FEEDBACK_ENDPOINT=/nutrition/feedback

# NORE booking / no-show / cancel bridge
NORE_RESERVATION_ENDPOINT=/reservations
NORE_RESERVATION_RECOMMEND_ENDPOINT=/reservations/recommend-slots
NORE_RESERVATION_NOTIFY_ENDPOINT=/reservations/no-show-notify

# NORE PE exam bridge
NORE_PE_EXAM_PROFILE_ENDPOINT=/pe-exam/profile
NORE_PE_EXAM_PLAN_ENDPOINT=/pe-exam/plan
